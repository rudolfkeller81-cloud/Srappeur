# ============================================================
# CONFIGURATION - Copiez ce fichier en .env et remplissez les valeurs
# ============================================================

# Clé API Google Maps Platform (obligatoire)
# Obtenir une clé : https://console.cloud.google.com/
# APIs à activer : Places API
# Coût : $200 de crédits gratuits/mois, puis ~$17 pour 1000 requêtes de détails
GOOGLE_PLACES_API_KEY=votre_cle_api_google_ici

# Dossier de sortie pour les fichiers CSV (optionnel, défaut: ./output)
OUTPUT_DIR=./output

# Délai entre les requêtes en millisecondes (optionnel, défaut: 200)
# Augmenter si vous obtenez des erreurs de rate limiting
REQUEST_DELAY_MS=200
